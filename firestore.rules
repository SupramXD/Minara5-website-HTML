rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: Check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function: Fetch user profile record
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function: Check if logged-in user is an Admin
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'Admin' || 
        request.auth.token.email == 'sub2meboyi@gmail.com'
      );
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // 1. Authenticated users can read their own profile; Admins can read all profiles
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // 2. Users can create their own document on registration, but must be 'Customer' role
      // (Primary owner email is exempted and allowed to register as Admin)
      allow create: if isAuthenticated() && request.auth.uid == userId && (
        request.resource.data.role == 'Customer' || 
        request.auth.token.email == 'sub2meboyi@gmail.com'
      );
      
      // 3. Users can update their own data, but CANNOT change their own role.
      // Admins can change other users' roles, but CANNOT modify or demote the primary owner.
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) || 
        (isAdmin() && userId != 'sub2meboyi@gmail.com' && resource.data.email != 'sub2meboyi@gmail.com')
      );
      
      // 4. Only admins can delete profiles (except primary owner)
      allow delete: if isAdmin() && resource.data.email != 'sub2meboyi@gmail.com';
    }
    
    // --- PRODUCTS COLLECTION ---
    match /products/{productId} {
      // Anyone (including guests) can read/view catalog products
      allow read: if true;
      
      // Only validated Admins can add, edit, or delete products
      allow write: if isAdmin();
    }
    
    // --- SUBSCRIBERS (NEWSLETTER) COLLECTION ---
    match /subscribers/{subscriberId} {
      // Anyone can subscribe (create a subscription document)
      allow create: if true;
      
      // Only validated Admins can view, edit, or delete subscriber emails
      allow read, update, delete: if isAdmin();
    }
  }
}
