rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // STRICT ADMIN CHECK: Must be authenticated AND have master admin email 'sub2meboyi@gmail.com' AND role == 'Admin'
    function isAdmin() {
      return request.auth != null && 
        request.auth.token.email == 'sub2meboyi@gmail.com' &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Users collection rules
    match /users/{userId} {
      // Users can read their own record
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Users can create/update their own profile, BUT CANNOT set role = 'Admin' unless they are sub2meboyi@gmail.com
      allow create, update: if request.auth != null && request.auth.uid == userId &&
        (request.resource.data.role != 'Admin' || request.auth.token.email == 'sub2meboyi@gmail.com');

      // Master Admin can read/write all user records
      allow read, write: if isAdmin();
    }

    // Subscribers collection rules
    match /subscribers/{subscriberId} {
      // Anyone can subscribe (write)
      allow create: if true;
      // Only admins can read/update/delete subscribers
      allow read, update, delete: if isAdmin();
    }

    // Reviews collection rules
    match /reviews/{reviewId} {
      // Anyone can create a review
      allow create: if true;
      // Only admins can read/update/delete directly (Cloud Functions bypass rules)
      allow read, update, delete: if isAdmin();
    }

    // Products collection rules
    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      // Only admins can write/update/delete products
      allow write: if isAdmin();
    }

    // Unsupported requests (fragrance search notifier)
    match /unsupported_requests/{requestId} {
      // Anyone can submit an unsupported request (create)
      allow create: if true;
      // Only admins can read/update/delete
      allow read, update, delete: if isAdmin();
    }

    // Out of stock notifications
    match /stock_notifications/{notificationId} {
      // Anyone can submit a stock notification (create)
      allow create: if true;
      // Only admins can read/update/delete
      allow read, update, delete: if isAdmin();
    }

    // Settings collection rules
    match /settings/{settingId} {
      // Only admins can read/write settings
      allow read, write: if isAdmin();
    }

    // Orders collection rules (STRICT ADMIN-ONLY SECURITY)
    match /orders/{orderId} {
      // ONLY authenticated Admins can read, query, list, or modify orders
      allow read, list, update, delete: if isAdmin();
      // Client-side creations disallowed (handled by Cloud Functions Admin SDK)
      allow create: if false;
    }
  }
}
